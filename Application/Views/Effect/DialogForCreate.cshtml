<dialog hx-dialog>
    <button hx-dialog-close class="btn btn-primary">x</button>
    <form hx-post="/Effect" autocomplete="off">
        <div>
            <label for="type">Type</label>
            <input type="text" name="type" autofocus />
        </div>
        <div>
            <label for="tag" >Tag</label>
            <select type="text" name="tag">
                <option value="Data">Data</option>
                <option value="Effect">Effect</option>
                <option value="Result">Result</option>
                <option value="Fault">Fault</option>
            </select>
        </div>
        <div>
            <label for="matter">Matter</label>
            <input type="text" name="matter" />
        </div>
        <div>
            <label for="json">Data</label>
            <input type="text" name="json" />
        </div>
        <button type="submit" class="btn btn-primary">emit</button>
    </form>
</dialog>
